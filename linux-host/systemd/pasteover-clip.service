[Unit]
Description=pasteover clip-server (Wayland clipboard over loopback for the builds VM)
Documentation=file:%h/pasteover/linux-host/README.md
After=graphical-session.target
PartOf=graphical-session.target

[Service]
Type=simple
ExecStart=%h/pasteover/linux-host/clip-server
Restart=always
RestartSec=2

[Install]
WantedBy=graphical-session.target
