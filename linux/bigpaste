#!/usr/bin/env bash
# bigpaste (pasteover) — pull LARGE text from the laptop clipboard over the
# pasteover SSH tunnel and drop it into a file the agent can read, bypassing the
# terminal / multiplexer paste-size truncation that mangles big pastes typed
# into the prompt.
#
# Companion to the xclip image shim. Talks to pasteover-server (the clipboard
# server on the laptop) over the SSH reverse tunnel on 127.0.0.1:18339, using the
# same dumb one-request-per-connection protocol:
#   send "CHECKTEXT\n" -> "TEXT\n" / "NONE\n"
#   send "GETTEXT\n"   -> clipboard text as raw UTF-8 bytes
#
# Usage — from the Claude Code prompt, on an empty line:
#   !bigpaste
# It saves the clipboard text and prints the path; the agent then reads the file.

set -euo pipefail

PORT="${PASTEOVER_PORT:-18339}"
HOST="${PASTEOVER_HOST:-127.0.0.1}"
INBOX="${PASTEOVER_INBOX:-/tmp/pasteover-inbox}"
# Bound every read: the tunnel accepts locally even when the laptop end is
# asleep/unreachable, so without this a stale connection hangs cat forever.
TIMEOUT="${PASTEOVER_TIMEOUT:-8}"

bridge() {  # bridge CHECKTEXT|GETTEXT  -> server response on stdout (empty on timeout)
    local cmd="$1"
    exec 3<>"/dev/tcp/$HOST/$PORT" 2>/dev/null || return 1
    printf '%s\n' "$cmd" >&3
    timeout "$TIMEOUT" cat <&3 || true
    exec 3<&- 3>&-
    return 0
}

resp="$(bridge CHECKTEXT 2>/dev/null || true)"
resp="${resp%%$'\r'*}"; resp="${resp%%$'\n'*}"

if [ "$resp" != "TEXT" ]; then
    {
        echo "pasteover: no text available from the laptop clipboard (got '${resp:-nothing}')."
        echo "  - clipboard actually holds text? (an image goes via Alt+V instead)"
        echo "  - tunnel up?  ss -tln | grep $PORT"
        echo "  - pasteover-server running on the laptop (serves CHECKTEXT/GETTEXT)?"
    } >&2
    exit 1
fi

mkdir -p -m 700 "$INBOX"
ts="$(date +%Y%m%d-%H%M%S)"
file="$INBOX/paste-$ts.txt"

bridge GETTEXT > "$file"

bytes=$(wc -c < "$file")
if [ "$bytes" -eq 0 ]; then
    echo "pasteover: clipboard text came back empty; nothing saved." >&2
    rm -f "$file"
    exit 1
fi

ln -sfn "$file" "$INBOX/latest.txt"

lines=$(wc -l < "$file")
echo "pasteover: saved $bytes bytes / $lines lines of clipboard text to:"
echo "  $file"
echo "Read that file to see the pasted content."
